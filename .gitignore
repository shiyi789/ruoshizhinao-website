# 如是智脑项目 .gitignore

# 依赖目录
node_modules/
venv/
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# 环境文件
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# 日志文件
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# 运行时数据
pids
*.pid
*.seed
*.pid.lock

# 覆盖率目录
coverage/
*.lcov

# 编辑器文件
.vscode/
.idea/
*.swp
*.swo
*~

# 系统文件
.DS_Store
Thumbs.db

# 测试文件
test-results/
reports/

# 构建输出
dist/
build/
out/
.next/

# 数据库文件
*.db
*.sqlite
*.sqlite3

# 临时文件
temp/
tmp/

# 配置文件（不包含模板）
config.json
secrets.json

# OpenClaw特定文件
.openclaw/cache/
.openclaw/tmp/

# 项目特定忽略
migration.log
move.log
test_*.txt
*.bak
*.bak.*